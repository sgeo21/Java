		if (numero >= 0 && (numero / 2 == 0)) {
			System.out.println("Este número é par e positivo");
		    }
		  else if(numero < 0 && (numero / 2 == 0)) {
			System.out.println("Este número é par e negativo");
			}
		  else if (numero >= 0 && (numero / 3 == 0)) {
			System.out.println("Este número é impare e positivo");
		    }
			else if (numero < 0 && (numero / 3 == 0)) {
				System.out.println("Este número é impare e negativo");
				}
           leia.close();

	}

}

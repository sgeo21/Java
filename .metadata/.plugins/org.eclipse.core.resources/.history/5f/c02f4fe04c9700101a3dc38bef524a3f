package listadeexercicios2;

import java.util.Scanner;

public class Exercício6 {

	public static void main(String[] args) {
		
		Scanner leia = new Scanner (System.in);
		String nomeColab;
		int cargo;
		float salarioAtual, salarioFinal;
		
		
		
		System.out.println("   1- Gerente   ");
		System.out.println("   2- Vendedor  ");
		System.out.println("   3- Supervisor");
		System.out.println("   4- Motorista ");
		System.out.println("   5- Estoquista");
		System.out.println("   6- Técnico TI");
		System.out.println("Selecione a opção referente ao cargo: ");
		cargo = leia.nextInt();
		
		System.out.println("Digite o nome do colaborador: ");
		nomeColab = leia.next();
		
		System.out.println("Digite o salário atual do colaborador: ");
		salarioAtual = leia.nextFloat();
		
		switch(cargo) {
		case 1: 
			salarioFinal = (float) ((0.10 * salarioAtual) + salarioAtual);
			System.out.printf("O salário do Gerente %s passa a ser: %.2f%n ", nomeColab, salarioFinal);
			break;
		case 2:
			salarioFinal = (float) ((0.7 * salarioAtual) + salarioAtual);
			System.out.printf("O salário do Vendedor %s passa a ser: %.2f%n ", nomeColab, salarioFinal);
			break;
         case 3: 
        	 salarioFinal = (float) ((0.9 * salarioAtual) + salarioAtual);
 			System.out.printf("O salário do Supervisor %s passa a ser: %.2f%n ", nomeColab, salarioFinal);
			break;
         case 4: 
 			salarioFinal = (float) ((0.6 * salarioAtual) + salarioAtual);
 			System.out.printf("O salário do Motorista %s passa a ser: %.2f%n ", nomeColab, salarioFinal);
 			break;
 		case 5:
 			salarioFinal = (float) ((0.5 * salarioAtual) + salarioAtual);
 			System.out.printf("O salário do Estoquista %s passa a ser: %.2f%n ", nomeColab, salarioFinal);
 			break;
          case 6: 
         	 salarioFinal = (float) ((0.8 * salarioAtual) + salarioAtual);
  			System.out.printf("O salário do Técnico de TI %s passa a ser: %.2f%n ", nomeColab, salarioFinal);
 			break;
 			default:
 			System.out.printf("Comando inválido!");
		}
		
		leia.close();
		

	}

}
